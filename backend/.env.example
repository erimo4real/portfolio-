PORT=4000
MONGO_URI=mongodb://localhost:27017/portfolio
DB_NAME=portfolio
JWT_SECRET=replace_this_with_a_secure_random_secret_key

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
NODE_ENV=production

FRONTEND_URL=http://localhost:5173

# Email (for password reset & error notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Portfolio Admin" <your-email@gmail.com>
ERROR_EMAIL_TO=your-email@gmail.com
ERROR_EMAIL_FROM=your-email@gmail.com

# Google OAuth (optional - for Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Cloudinary (for image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Sentry Error Tracking (optional - get from sentry.io)
SENTRY_DSN=