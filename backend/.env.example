PORT=4000
MONGO_URI=mongodb://localhost:27017/portfolio
DB_NAME=portfolio
JWT_SECRET=replace_this_with_a_secure_secret

# Production settings
NODE_ENV=production

# Email (optional - for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
